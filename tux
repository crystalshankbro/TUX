#!/usr/bin/env bash

# ═══════════════════════════════════════════════════════════════════
#   TUX — Package Manager & APK/AAB Builder  v3.0
#   Поддержка: Linux · Windows (Git Bash/MSYS2/WSL) · macOS
#
#   Новое в v3.0:
#     • Интерактивное меню (просто запусти: tux)
#     • Новые языки: Gradle, Python, Node.js
#     • Сборка AAB (Android App Bundle для Google Play)
#     • Release-подпись APK своим ключом
#     • Логи сборки в ~/.tux/logs/
#     • tux list — таблица всего установленного
# ═══════════════════════════════════════════════════════════════════

set -euo pipefail

# ══════════════════════════════════════════════════════════════════
#  ЦВЕТА
# ══════════════════════════════════════════════════════════════════
RED='\033[0;31m';    GREEN='\033[0;32m';   YELLOW='\033[1;33m'
CYAN='\033[0;36m';   BLUE='\033[0;34m';    MAGENTA='\033[0;35m'
WHITE='\033[1;37m';  BOLD='\033[1m';       DIM='\033[2m'
RESET='\033[0m';     BG_BLUE='\033[44m';   BG_CYAN='\033[46m'
REVERSE='\033[7m'

# ══════════════════════════════════════════════════════════════════
#  ОПРЕДЕЛЕНИЕ ОС
# ══════════════════════════════════════════════════════════════════
detect_os() {
    case "$(uname -s)" in
        Linux*)        OS="linux"   ;;
        Darwin*)       OS="mac"     ;;
        CYGWIN*|MINGW*|MSYS*) OS="windows" ;;
        *)
            grep -qi microsoft /proc/version 2>/dev/null \
                && OS="linux" || OS="linux" ;;
    esac
    export OS
}
detect_os

# ══════════════════════════════════════════════════════════════════
#  ПУТИ
# ══════════════════════════════════════════════════════════════════
if [ "$OS" = "windows" ]; then
    INSTALL_DIR="${USERPROFILE:-$HOME}/.tux"
    TMP_DIR="${TEMP:-/tmp}/tux_build"
    EXE_EXT=".exe"
else
    INSTALL_DIR="$HOME/.tux"
    TMP_DIR="/tmp/tux_build"
    EXE_EXT=""
fi

JAVA_DIR="$INSTALL_DIR/java"
KOTLIN_DIR="$INSTALL_DIR/kotlin"
GRADLE_DIR="$INSTALL_DIR/gradle"
PYTHON_DIR="$INSTALL_DIR/python"
NODE_DIR="$INSTALL_DIR/node"
TOOLS_DIR="$INSTALL_DIR/tools"
BIN_DIR="$INSTALL_DIR/bin"
LOGS_DIR="$INSTALL_DIR/logs"

# Maven Google (без SDK)
D8_URL="https://maven.google.com/com/android/tools/build/r8/8.3.37/r8-8.3.37.jar"
D8_FB="https://maven.google.com/com/android/tools/build/r8/3.3.75/r8-3.3.75.jar"
APKSIG_URL="https://maven.google.com/com/android/apksig/apksig/8.3.0/apksig-8.3.0.jar"
APKSIG_FB="https://maven.google.com/com/android/apksig/apksig/7.4.2/apksig-7.4.2.jar"
ANDROID_JAR_URL="https://github.com/Sable/android-platforms/raw/master/android-34/android.jar"
ANDROID_JAR_FB1="https://github.com/Sable/android-platforms/raw/master/android-33/android.jar"
ANDROID_JAR_FB2="https://github.com/Sable/android-platforms/raw/master/android-32/android.jar"

# ══════════════════════════════════════════════════════════════════
#  ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# ══════════════════════════════════════════════════════════════════
has_cmd() { command -v "$1" &>/dev/null; }

info()    { echo -e "${CYAN}[•]${RESET} $1"; }
success() { echo -e "${GREEN}[✓]${RESET} $1"; }
warn()    { echo -e "${YELLOW}[!]${RESET} $1"; }
error()   { echo -e "${RED}[✗]${RESET} $1" >&2; }
step()    { echo -e "\n${MAGENTA}[→]${RESET} ${BOLD}$1${RESET}"; }
divider() { echo -e "${DIM}  ──────────────────────────────────────${RESET}"; }

# Логирование — пишем и в консоль и в файл
LOG_FILE=""
log_init() {
    mkdir -p "$LOGS_DIR"
    LOG_FILE="$LOGS_DIR/$(date +%Y%m%d_%H%M%S)_${1}.log"
    echo "=== TUX LOG: $1  $(date) ===" > "$LOG_FILE"
    echo "OS: $OS  |  Tux v3.0" >> "$LOG_FILE"
    echo "" >> "$LOG_FILE"
}

log_line() {
    # Пишем в лог без ANSI-кодов
    echo "$1" | sed 's/\x1b\[[0-9;]*m//g' >> "$LOG_FILE"
}

# info/success/warn/error с дублированием в лог
linfo()    { info "$1";    [ -n "$LOG_FILE" ] && log_line "[INFO]  $1"; }
lsuccess() { success "$1"; [ -n "$LOG_FILE" ] && log_line "[OK]    $1"; }
lwarn()    { warn "$1";    [ -n "$LOG_FILE" ] && log_line "[WARN]  $1"; }
lerror()   { error "$1";   [ -n "$LOG_FILE" ] && log_line "[ERROR] $1"; }
lstep()    { step "$1";    [ -n "$LOG_FILE" ] && log_line "\n>>> $1"; }

download() {
    local url="$1" dest="$2"
    [ -n "$LOG_FILE" ] && log_line "DOWNLOAD: $url -> $dest"
    if has_cmd curl; then
        curl -fsSL --progress-bar "$url" -o "$dest"
    elif has_cmd wget; then
        wget -q --show-progress "$url" -O "$dest"
    else
        lerror "Нужен curl или wget!"; exit 1
    fi
}

add_to_path() {
    local p="$1"
    for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.profile"; do
        [ -f "$rc" ] && ! grep -qF "$p" "$rc" && {
            printf '\n# Added by Tux\nexport PATH="%s:$PATH"\n' "$p" >> "$rc"
        }
    done
    export PATH="$p:$PATH"
}

find_java()    {
    [ -f "$JAVA_DIR/bin/java${EXE_EXT}" ]     && echo "$JAVA_DIR/bin/java${EXE_EXT}" && return
    has_cmd java    && echo "java"    && return; echo ""
}
find_kotlinc() {
    [ -f "$KOTLIN_DIR/bin/kotlinc" ]           && echo "$KOTLIN_DIR/bin/kotlinc" && return
    [ -f "$KOTLIN_DIR/bin/kotlinc.bat" ]       && echo "$KOTLIN_DIR/bin/kotlinc.bat" && return
    has_cmd kotlinc && echo "kotlinc" && return; echo ""
}

# ══════════════════════════════════════════════════════════════════
#  БАННЕР
# ══════════════════════════════════════════════════════════════════
print_banner() {
    echo ""
    echo -e "${CYAN}${BOLD}"
    echo "  ████████╗██╗   ██╗██╗  ██╗"
    echo "     ██╔══╝██║   ██║╚██╗██╔╝"
    echo "     ██║   ██║   ██║ ╚███╔╝ "
    echo "     ██║   ██║   ██║ ██╔██╗ "
    echo "     ██║   ╚██████╔╝██╔╝ ██╗"
    echo "     ╚═╝    ╚═════╝ ╚═╝  ╚═╝"
    echo -e "${RESET}${DIM}  Package Manager v3.0  |  ${OS}${RESET}"
    echo ""
}

# ══════════════════════════════════════════════════════════════════
#  ИНТЕРАКТИВНОЕ МЕНЮ (стрелки + Enter)
# ══════════════════════════════════════════════════════════════════
interactive_menu() {
    # Категории
    local CATEGORIES=(
        "📦  Установка языков"
        "🔨  Сборка APK / AAB"
        "📋  tux list — что установлено"
        "📄  Логи сборки"
        "🔧  Обновить инструменты APK"
        "❓  Справка"
        "🚪  Выход"
    )

    # Подменю установки
    local INSTALL_ITEMS=(
        "☕  Java (Adoptium Temurin LTS)"
        "🎯  Kotlin (JetBrains)"
        "🐘  Gradle (последняя стабильная)"
        "🐍  Python (последняя стабильная)"
        "💚  Node.js (LTS)"
        "← Назад"
    )

    # Подменю сборки
    local BUILD_ITEMS=(
        "📱  APK (debug) из .kt файлов"
        "📱  APK (release) — с подписью своим ключом"
        "📦  AAB (Android App Bundle для Google Play)"
        "← Назад"
    )

    local sel=0
    local in_sub=""

    # Сохраняем/восстанавливаем настройки терминала
    local old_tty=""
    old_tty=$(stty -g 2>/dev/null || echo "")
    trap '[ -n "$old_tty" ] && stty "$old_tty" 2>/dev/null; echo -e "${RESET}"; exit 0' INT TERM EXIT

    while true; do
        clear
        print_banner

        if [ -z "$in_sub" ]; then
            echo -e "  ${BOLD}Главное меню${RESET}  ${DIM}(↑↓ для навигации, Enter для выбора)${RESET}"
            echo ""
            local i=0
            for item in "${CATEGORIES[@]}"; do
                if [ $i -eq $sel ]; then
                    echo -e "  ${REVERSE}${CYAN}  $item  ${RESET}"
                else
                    echo -e "     ${DIM}$item${RESET}"
                fi
                ((i++))
            done
            echo ""

            # Показываем статус установленных
            echo -e "  ${DIM}Установлено: $(list_installed_short)${RESET}"
            echo ""

            stty -echo -icanon min 1 time 0 2>/dev/null || true
            local key
            IFS= read -r -s -n1 key
            if [[ "$key" == $'\x1b' ]]; then
                IFS= read -r -s -n2 seq
                case "$seq" in
                    '[A') ((sel > 0)) && ((sel--)) ;;
                    '[B') ((sel < ${#CATEGORIES[@]}-1)) && ((sel++)) ;;
                esac
            elif [[ "$key" == "" || "$key" == $'\n' ]]; then
                stty "$old_tty" 2>/dev/null || true
                case $sel in
                    0) in_sub="install"; sel=0 ;;
                    1) in_sub="build";   sel=0 ;;
                    2) clear; show_list; echo ""; read -rsp "  Нажми Enter..."; sel=0 ;;
                    3) clear; show_logs_menu; sel=0 ;;
                    4) clear; update_tools; echo ""; read -rsp "  Нажми Enter..."; sel=0 ;;
                    5) clear; show_help; echo ""; read -rsp "  Нажми Enter..."; sel=0 ;;
                    6) stty "$old_tty" 2>/dev/null; trap - INT TERM EXIT; echo -e "${RESET}"; exit 0 ;;
                esac
            fi

        elif [ "$in_sub" = "install" ]; then
            echo -e "  ${BOLD}Установка языков${RESET}  ${DIM}(↑↓ + Enter)${RESET}"
            echo ""
            local i=0
            for item in "${INSTALL_ITEMS[@]}"; do
                if [ $i -eq $sel ]; then
                    echo -e "  ${REVERSE}${CYAN}  $item  ${RESET}"
                else
                    echo -e "     ${DIM}$item${RESET}"
                fi
                ((i++))
            done
            echo ""

            stty -echo -icanon min 1 time 0 2>/dev/null || true
            local key
            IFS= read -r -s -n1 key
            if [[ "$key" == $'\x1b' ]]; then
                IFS= read -r -s -n2 seq
                case "$seq" in
                    '[A') ((sel > 0)) && ((sel--)) ;;
                    '[B') ((sel < ${#INSTALL_ITEMS[@]}-1)) && ((sel++)) ;;
                esac
            elif [[ "$key" == "" || "$key" == $'\n' ]]; then
                stty "$old_tty" 2>/dev/null || true
                clear
                case $sel in
                    0) install_java;   echo ""; read -rsp "  Нажми Enter..." ;;
                    1) install_kotlin; echo ""; read -rsp "  Нажми Enter..." ;;
                    2) install_gradle; echo ""; read -rsp "  Нажми Enter..." ;;
                    3) install_python; echo ""; read -rsp "  Нажми Enter..." ;;
                    4) install_node;   echo ""; read -rsp "  Нажми Enter..." ;;
                    5) in_sub=""; sel=0; continue ;;
                esac
                in_sub="install"
            fi

        elif [ "$in_sub" = "build" ]; then
            echo -e "  ${BOLD}Сборка APK / AAB${RESET}  ${DIM}(↑↓ + Enter)${RESET}"
            echo ""
            local i=0
            for item in "${BUILD_ITEMS[@]}"; do
                if [ $i -eq $sel ]; then
                    echo -e "  ${REVERSE}${CYAN}  $item  ${RESET}"
                else
                    echo -e "     ${DIM}$item${RESET}"
                fi
                ((i++))
            done
            echo ""

            stty -echo -icanon min 1 time 0 2>/dev/null || true
            local key
            IFS= read -r -s -n1 key
            if [[ "$key" == $'\x1b' ]]; then
                IFS= read -r -s -n2 seq
                case "$seq" in
                    '[A') ((sel > 0)) && ((sel--)) ;;
                    '[B') ((sel < ${#BUILD_ITEMS[@]}-1)) && ((sel++)) ;;
                esac
            elif [[ "$key" == "" || "$key" == $'\n' ]]; then
                stty "$old_tty" 2>/dev/null || true
                clear
                case $sel in
                    0)
                        echo -ne "  ${CYAN}Файлы (через +): ${RESET}"
                        read -r files
                        [ -n "$files" ] && install_apk "$files" "debug"
                        echo ""; read -rsp "  Нажми Enter..."
                        ;;
                    1)
                        echo -ne "  ${CYAN}Файлы (через +): ${RESET}"
                        read -r files
                        [ -n "$files" ] && install_apk "$files" "release"
                        echo ""; read -rsp "  Нажми Enter..."
                        ;;
                    2)
                        echo -ne "  ${CYAN}Файлы (через +): ${RESET}"
                        read -r files
                        [ -n "$files" ] && build_aab "$files"
                        echo ""; read -rsp "  Нажми Enter..."
                        ;;
                    3) in_sub=""; sel=0; continue ;;
                esac
                in_sub="build"
            fi
        fi
    done
}

# Короткий список установленного для строки статуса
list_installed_short() {
    local installed=()
    [ -f "$JAVA_DIR/bin/java${EXE_EXT}" ]   && installed+=("Java")
    [ -d "$KOTLIN_DIR/bin" ]                && installed+=("Kotlin")
    [ -d "$GRADLE_DIR/bin" ]                && installed+=("Gradle")
    [ -d "$PYTHON_DIR" ]                    && installed+=("Python")
    [ -d "$NODE_DIR/bin" ]                  && installed+=("Node.js")
    [ ${#installed[@]} -eq 0 ] && echo "ничего" && return
    local IFS=', '; echo "${installed[*]}"
}

# ══════════════════════════════════════════════════════════════════
#  TUX LIST — таблица установленного
# ══════════════════════════════════════════════════════════════════
show_list() {
    print_banner
    echo -e "  ${BOLD}Установленные компоненты${RESET}"
    echo ""
    divider
    printf "  ${BOLD}%-12s %-20s %-10s %s${RESET}\n" "Пакет" "Версия" "Размер" "Путь"
    divider

    # Java
    if [ -f "$JAVA_DIR/bin/java${EXE_EXT}" ]; then
        local jv sz
        jv=$("$JAVA_DIR/bin/java${EXE_EXT}" -version 2>&1 | head -1 | grep -oP '"\K[^"]+' | head -1)
        sz=$(du -sh "$JAVA_DIR" 2>/dev/null | cut -f1)
        printf "  ${GREEN}✓${RESET} %-10s %-20s %-10s ${DIM}%s${RESET}\n" "Java" "$jv" "$sz" "$JAVA_DIR"
    else
        printf "  ${RED}✗${RESET} %-10s ${DIM}%-20s${RESET}\n" "Java" "не установлена"
    fi

    # Kotlin
    local kc; kc="$(find_kotlinc)"
    if [ -n "$kc" ]; then
        local kv sz
        kv=$("$kc" -version 2>&1 | grep -oP 'kotlinc-jvm \K\S+' | head -1)
        [ -z "$kv" ] && kv=$("$kc" -version 2>&1 | head -1 | awk '{print $NF}')
        sz=$(du -sh "$KOTLIN_DIR" 2>/dev/null | cut -f1)
        printf "  ${GREEN}✓${RESET} %-10s %-20s %-10s ${DIM}%s${RESET}\n" "Kotlin" "$kv" "$sz" "$KOTLIN_DIR"
    else
        printf "  ${RED}✗${RESET} %-10s ${DIM}%-20s${RESET}\n" "Kotlin" "не установлен"
    fi

    # Gradle
    if [ -f "$GRADLE_DIR/bin/gradle" ] || [ -f "$GRADLE_DIR/bin/gradle.bat" ]; then
        local gv sz
        gv=$("$GRADLE_DIR/bin/gradle" --version 2>/dev/null | grep "^Gradle" | awk '{print $2}')
        sz=$(du -sh "$GRADLE_DIR" 2>/dev/null | cut -f1)
        printf "  ${GREEN}✓${RESET} %-10s %-20s %-10s ${DIM}%s${RESET}\n" "Gradle" "$gv" "$sz" "$GRADLE_DIR"
    else
        printf "  ${RED}✗${RESET} %-10s ${DIM}%-20s${RESET}\n" "Gradle" "не установлен"
    fi

    # Python
    if [ -f "$PYTHON_DIR/bin/python3" ] || [ -f "$PYTHON_DIR/python.exe" ]; then
        local pv sz pbin
        pbin="${PYTHON_DIR}/bin/python3"; [ "$OS" = "windows" ] && pbin="$PYTHON_DIR/python.exe"
        pv=$("$pbin" --version 2>&1 | awk '{print $2}')
        sz=$(du -sh "$PYTHON_DIR" 2>/dev/null | cut -f1)
        printf "  ${GREEN}✓${RESET} %-10s %-20s %-10s ${DIM}%s${RESET}\n" "Python" "$pv" "$sz" "$PYTHON_DIR"
    else
        printf "  ${RED}✗${RESET} %-10s ${DIM}%-20s${RESET}\n" "Python" "не установлен"
    fi

    # Node.js
    if [ -f "$NODE_DIR/bin/node" ] || [ -f "$NODE_DIR/node.exe" ]; then
        local nv sz nbin
        nbin="$NODE_DIR/bin/node"; [ "$OS" = "windows" ] && nbin="$NODE_DIR/node.exe"
        nv=$("$nbin" --version 2>/dev/null)
        sz=$(du -sh "$NODE_DIR" 2>/dev/null | cut -f1)
        printf "  ${GREEN}✓${RESET} %-10s %-20s %-10s ${DIM}%s${RESET}\n" "Node.js" "$nv" "$sz" "$NODE_DIR"
    else
        printf "  ${RED}✗${RESET} %-10s ${DIM}%-20s${RESET}\n" "Node.js" "не установлен"
    fi

    divider
    echo ""

    # APK инструменты
    echo -e "  ${BOLD}Инструменты APK:${RESET}"
    echo ""
    for item in "r8.jar:R8/D8 DEX" "android.jar:Android API" "apksig.jar:APK Signer" "tux.keystore:Keystore"; do
        local f="${item%%:*}" lbl="${item##*:}"
        if [ -f "$TOOLS_DIR/$f" ]; then
            local sz; sz=$(du -sh "$TOOLS_DIR/$f" | cut -f1)
            printf "    ${GREEN}✓${RESET} %-16s ${DIM}%s${RESET}\n" "$lbl" "$sz"
        else
            printf "    ${YELLOW}–${RESET} %-16s ${DIM}(скачается при сборке)${RESET}\n" "$lbl"
        fi
    done

    echo ""
    # Логи
    if [ -d "$LOGS_DIR" ]; then
        local log_count; log_count=$(ls "$LOGS_DIR"/*.log 2>/dev/null | wc -l)
        echo -e "  ${DIM}Логов сборки: ${log_count}  (${CYAN}tux logs${RESET}${DIM})${RESET}"
    fi
    echo ""
}

# ══════════════════════════════════════════════════════════════════
#  ЛОГИ
# ══════════════════════════════════════════════════════════════════
show_logs_menu() {
    print_banner
    echo -e "  ${BOLD}Логи сборки${RESET}  ${DIM}(${LOGS_DIR})${RESET}"
    echo ""

    if [ ! -d "$LOGS_DIR" ] || [ -z "$(ls "$LOGS_DIR"/*.log 2>/dev/null)" ]; then
        warn "Логов пока нет. Собери APK/AAB и лог появится."
        echo ""
        return
    fi

    divider
    local i=1
    local files=()
    while IFS= read -r f; do
        files+=("$f")
        local size; size=$(du -sh "$f" | cut -f1)
        local name; name=$(basename "$f")
        printf "  ${CYAN}[%d]${RESET} %-40s ${DIM}%s${RESET}\n" "$i" "$name" "$size"
        ((i++))
    done < <(ls -t "$LOGS_DIR"/*.log 2>/dev/null | head -20)
    divider
    echo ""
    echo -ne "  Открыть лог [1-$((i-1))] или Enter для выхода: "
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -lt "$i" ]; then
        local idx=$((choice-1))
        echo ""
        echo -e "${DIM}$(cat "${files[$idx]}")${RESET}"
        echo ""
    fi
}

show_logs() {
    print_banner
    show_logs_menu
}

# ══════════════════════════════════════════════════════════════════
#  УСТАНОВКА JAVA
# ══════════════════════════════════════════════════════════════════
install_java() {
    print_banner
    log_init "install_java"
    lstep "Установка Java (последняя LTS — Adoptium Temurin)"
    divider

    local arch
    case "$(uname -m)" in
        x86_64|amd64)  arch="x64"     ;;
        aarch64|arm64) arch="aarch64" ;;
        *)             arch="x64"     ;;
    esac
    local api_os; [ "$OS" = "windows" ] && api_os="windows" || api_os="linux"
    [ "$OS" = "mac" ] && api_os="mac"

    linfo "Платформа: ${BOLD}${api_os}/${arch}${RESET}"
    linfo "Запрашиваю api.adoptium.net..."

    local meta url version
    meta=$(curl -fsSL \
        "https://api.adoptium.net/v3/assets/latest/21/hotspot?architecture=${arch}&image_type=jdk&os=${api_os}&vendor=eclipse" \
        2>/dev/null) || { lerror "Нет соединения с api.adoptium.net"; exit 1; }

    url=$(echo "$meta"     | grep -o '"link":"[^"]*"'           | head -1 | cut -d'"' -f4)
    version=$(echo "$meta" | grep -o '"openjdk_version":"[^"]*"' | head -1 | cut -d'"' -f4)
    [ -z "$url" ] && { lerror "Не удалось получить URL"; exit 1; }
    linfo "Версия: ${BOLD}${version}${RESET}"
    log_line "URL: $url"

    local ext="tar.gz"
    [ "$OS" = "windows" ] && ext="zip"
    [ "$OS" = "mac" ]     && ext="tar.gz"
    local archive="$TMP_DIR/jdk.${ext}"
    mkdir -p "$TMP_DIR"

    lstep "Скачиваю JDK ${version}..."
    download "$url" "$archive"

    lstep "Распаковываю..."
    rm -rf "$JAVA_DIR"; mkdir -p "$JAVA_DIR"
    if [ "$ext" = "zip" ]; then
        unzip -q "$archive" -d "$TMP_DIR/jdk_tmp"
        local inner; inner=$(ls "$TMP_DIR/jdk_tmp" | head -1)
        mv "$TMP_DIR/jdk_tmp/$inner"/* "$JAVA_DIR/" 2>/dev/null || \
        mv "$TMP_DIR/jdk_tmp/$inner"   "$JAVA_DIR/"
        rm -rf "$TMP_DIR/jdk_tmp"
    else
        tar -xzf "$archive" -C "$JAVA_DIR" --strip-components=1
    fi
    rm -f "$archive"

    mkdir -p "$BIN_DIR"
    if [ "$OS" = "windows" ]; then
        for b in java javac jar keytool; do
