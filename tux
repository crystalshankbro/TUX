# ══════════════════════════════════════════════════════════════════
#  УСТАНОВКА PYTHON
# ══════════════════════════════════════════════════════════════════
install_python() {
    print_banner
    log_init "install_python"
    lstep "Установка Python (последняя стабильная)"
    divider

    # Определяем последнюю версию через python.org API
    linfo "Запрашиваю python.org..."
    local version
    version=$(curl -fsSL "https://endoflife.date/api/python.json" 2>/dev/null \
        | grep -o '"latest":"[^"]*"' | head -1 | cut -d'"' -f4)
    [ -z "$version" ] && version="3.12.3"  # fallback
    linfo "Версия: ${BOLD}${version}${RESET}"

    if [ "$OS" = "linux" ]; then
        # Проверяем есть ли системный Python достаточной версии
        if has_cmd python3; then
            local sys_ver
            sys_ver=$(python3 --version 2>&1 | awk '{print $2}')
            linfo "Системный Python: $sys_ver"
            echo -ne "  Использовать системный Python ${sys_ver}? [Y/n]: "
            read -r ans
            if [[ ! "$ans" =~ ^[Nn]$ ]]; then
                local py_bin; py_bin=$(which python3)
                mkdir -p "$PYTHON_DIR/bin"
                ln -sf "$py_bin" "$PYTHON_DIR/bin/python3"
                lsuccess "Python $sys_ver (системный) зарегистрирован"
                return
            fi
        fi

        # Устанавливаем через пакетный менеджер
        if has_cmd apt-get; then
            linfo "Устанавливаю через apt..."
            sudo apt-get update -qq && sudo apt-get install -y python3 python3-pip
            local py_bin; py_bin=$(which python3)
            mkdir -p "$PYTHON_DIR/bin"
            ln -sf "$py_bin" "$PYTHON_DIR/bin/python3"
        elif has_cmd dnf; then
            sudo dnf install -y python3 python3-pip
            mkdir -p "$PYTHON_DIR/bin"
            ln -sf "$(which python3)" "$PYTHON_DIR/bin/python3"
        elif has_cmd pacman; then
            sudo pacman -S --noconfirm python python-pip
            mkdir -p "$PYTHON_DIR/bin"
            ln -sf "$(which python3)" "$PYTHON_DIR/bin/python3"
        else
            # Скачиваем portable Python через pyenv
            linfo "Устанавливаю через pyenv..."
            if [ ! -d "$HOME/.pyenv" ]; then
                curl -fsSL https://pyenv.run | bash
            fi
            export PYENV_ROOT="$HOME/.pyenv"
            export PATH="$PYENV_ROOT/bin:$PATH"
            eval "$(pyenv init -)"
            pyenv install -s "$version"
            pyenv global "$version"
            mkdir -p "$PYTHON_DIR/bin"
            ln -sf "$(pyenv which python3)" "$PYTHON_DIR/bin/python3"
        fi

    elif [ "$OS" = "windows" ]; then
        # Windows — скачиваем embeddable python
        local arch="amd64"
        local py_short="${version%.*}"
        local url="https://www.python.org/ftp/python/${version}/python-${version}-embed-amd64.zip"
        local archive="$TMP_DIR/python.zip"
        mkdir -p "$TMP_DIR"
        lstep "Скачиваю Python ${version} (embeddable)..."
        download "$url" "$archive"
        lstep "Распаковываю..."
        rm -rf "$PYTHON_DIR"; mkdir -p "$PYTHON_DIR"
        unzip -q "$archive" -d "$PYTHON_DIR"
        rm -f "$archive"
        mkdir -p "$BIN_DIR"
        cp "$PYTHON_DIR/python.exe" "$BIN_DIR/python3.exe" 2>/dev/null || true

    elif [ "$OS" = "mac" ]; then
        if has_cmd brew; then
            brew install python3
            mkdir -p "$PYTHON_DIR/bin"
            ln -sf "$(which python3)" "$PYTHON_DIR/bin/python3"
        else
            lwarn "Установи Homebrew для macOS: brew install python3"
        fi
    fi

    add_to_path "$BIN_DIR"

    echo ""
    divider
    lsuccess "Python установлен!"
    [ -f "$PYTHON_DIR/bin/python3" ] && \
        echo -e "  ${DIM}Версия: $("$PYTHON_DIR/bin/python3" --version 2>&1)${RESET}"
    echo -e "  ${DIM}Лог: ${LOG_FILE}${RESET}"
    echo ""
}

# ══════════════════════════════════════════════════════════════════
#  УСТАНОВКА NODE.JS
# ══════════════════════════════════════════════════════════════════
install_node() {
    print_banner
    log_init "install_node"
    lstep "Установка Node.js (LTS)"
    divider

    linfo "Запрашиваю nodejs.org..."
    local meta version
    meta=$(curl -fsSL "https://nodejs.org/dist/index.json" 2>/dev/null)
    # Берём последнюю LTS
    version=$(echo "$meta" | grep -o '"version":"[^"]*","date":"[^"]*","files":[^,]*,"npm":"[^"]*","v8":"[^"]*","uv":"[^"]*","zlib":"[^"]*","openssl":"[^"]*","modules":"[^"]*","lts":"[^"]*"' \
        | grep '"lts":"[^f]' | head -1 | grep -o '"version":"[^"]*"' | cut -d'"' -f4 | sed 's/^v//')
    # fallback простым способом
    [ -z "$version" ] && version=$(echo "$meta" | python3 -c \
        "import sys,json; d=json.load(sys.stdin); \
         lts=[x for x in d if x.get('lts') and x.get('lts')!=False]; \
         print(lts[0]['version'].lstrip('v')) if lts else print('20.11.0')" 2>/dev/null || echo "20.11.0")

    linfo "Версия: ${BOLD}${version}${RESET}"

    local arch_str platform
    case "$(uname -m)" in
        x86_64|amd64)  arch_str="x64"   ;;
        aarch64|arm64) arch_str="arm64" ;;
        *)             arch_str="x64"   ;;
    esac

    local url ext
    case "$OS" in
        linux)
            ext="tar.xz"
            url="https://nodejs.org/dist/v${version}/node-v${version}-linux-${arch_str}.${ext}"
            ;;
        mac)
            ext="tar.gz"
            url="https://nodejs.org/dist/v${version}/node-v${version}-darwin-${arch_str}.${ext}"
            ;;
        windows)
            ext="zip"
            url="https://nodejs.org/dist/v${version}/node-v${version}-win-${arch_str}.${ext}"
            ;;
    esac

    local archive="$TMP_DIR/node.${ext}"
    mkdir -p "$TMP_DIR"
    lstep "Скачиваю Node.js ${version}..."
    download "$url" "$archive"

    lstep "Распаковываю..."
    rm -rf "$NODE_DIR"; mkdir -p "$NODE_DIR"
    if [ "$ext" = "zip" ]; then
        unzip -q "$archive" -d "$TMP_DIR/node_tmp"
        local inner; inner=$(ls "$TMP_DIR/node_tmp" | head -1)
        mv "$TMP_DIR/node_tmp/$inner"/* "$NODE_DIR/"
        rm -rf "$TMP_DIR/node_tmp"
    elif [ "$ext" = "tar.xz" ]; then
        tar -xJf "$archive" -C "$NODE_DIR" --strip-components=1
    else
        tar -xzf "$archive" -C "$NODE_DIR" --strip-components=1
    fi
    rm -f "$archive"

    mkdir -p "$BIN_DIR"
    if [ "$OS" = "windows" ]; then
        [ -f "$NODE_DIR/node.exe" ] && cp "$NODE_DIR/node.exe" "$BIN_DIR/node.exe"
        [ -f "$NODE_DIR/npm.cmd" ]  && cp "$NODE_DIR/npm.cmd"  "$BIN_DIR/npm.cmd"
    else
        ln -sf "$NODE_DIR/bin/node" "$BIN_DIR/node"
        ln -sf "$NODE_DIR/bin/npm"  "$BIN_DIR/npm"
        [ -f "$NODE_DIR/bin/npx" ] && ln -sf "$NODE_DIR/bin/npx" "$BIN_DIR/npx"
    fi
    add_to_path "$BIN_DIR"

    echo ""
    divider
    lsuccess "Node.js ${version} установлен!"
    echo -e "  ${DIM}node --version && npm --version${RESET}"
    echo -e "  ${DIM}Лог: ${LOG_FILE}${RESET}"
    echo ""
}

# ══════════════════════════════════════════════════════════════════
#  ЗАГРУЗКА ИНСТРУМЕНТОВ APK
# ══════════════════════════════════════════════════════════════════
ensure_apk_tools() {
    local force="${1:-}"
    local need=false
    [ ! -f "$TOOLS_DIR/r8.jar"      ] && need=true
    [ ! -f "$TOOLS_DIR/android.jar" ] && need=true
    [ ! -f "$TOOLS_DIR/apksig.jar"  ] && need=true
    [ -n "$force" ] && need=true
    [ "$need" = false ] && return 0

    step "Загружаю инструменты сборки APK..."
    mkdir -p "$TOOLS_DIR"

    if [ ! -f "$TOOLS_DIR/r8.jar" ] || [ -n "$force" ]; then
        info "R8/D8 DEX Compiler (Google Maven)..."
        download "$D8_URL" "$TOOLS_DIR/r8.jar" 2>/dev/null || \
        download "$D8_FB"  "$TOOLS_DIR/r8.jar" || { error "Не удалось скачать r8.jar"; exit 1; }
        success "  r8.jar ($(du -sh "$TOOLS_DIR/r8.jar" | cut -f1))"
    fi

    if [ ! -f "$TOOLS_DIR/android.jar" ] || [ -n "$force" ]; then
        info "Android API stubs (android.jar)..."
        download "$ANDROID_JAR_URL"  "$TOOLS_DIR/android.jar" 2>/dev/null || \
        download "$ANDROID_JAR_FB1"  "$TOOLS_DIR/android.jar" 2>/dev/null || \
        download "$ANDROID_JAR_FB2"  "$TOOLS_DIR/android.jar" || { error "Не удалось скачать android.jar"; exit 1; }
        success "  android.jar ($(du -sh "$TOOLS_DIR/android.jar" | cut -f1))"
    fi

    if [ ! -f "$TOOLS_DIR/apksig.jar" ] || [ -n "$force" ]; then
        info "APK Signer (apksig, Google Maven)..."
        download "$APKSIG_URL" "$TOOLS_DIR/apksig.jar" 2>/dev/null || \
        download "$APKSIG_FB"  "$TOOLS_DIR/apksig.jar" 2>/dev/null || \
            warn "  apksig не скачался — APK без подписи"
        [ -f "$TOOLS_DIR/apksig.jar" ] && \
            success "  apksig.jar ($(du -sh "$TOOLS_DIR/apksig.jar" | cut -f1))"
    fi

    # Генерируем debug keystore
    if [ ! -f "$TOOLS_DIR/tux-debug.keystore" ]; then
        local kt="$JAVA_DIR/bin/keytool${EXE_EXT}"
        has_cmd keytool && kt="keytool"
        if [ -f "$kt" ] || has_cmd keytool; then
            info "Генерирую debug keystore..."
            "$kt" -genkeypair \
                -keystore "$TOOLS_DIR/tux-debug.keystore" \
                -alias tuxdebug -keyalg RSA -keysize 2048 -validity 9999 \
                -storepass tuxdebug -keypass tuxdebug \
                -dname "CN=TuxDebug,O=Tux,C=US" 2>/dev/null && \
                success "  tux-debug.keystore создан" || warn "  Keystore не создан"
        fi
    fi
    echo ""
}

# ══════════════════════════════════════════════════════════════════
#  УПАКОВКА APK В ZIP
# ══════════════════════════════════════════════════════════════════
pack_apk_zip() {
    local apk_dir="$1" output="$2"
    # Перечень файлов для упаковки
    local files=()
    [ -f "$apk_dir/classes.dex"         ] && files+=("classes.dex")
    [ -f "$apk_dir/AndroidManifest.xml" ] && files+=("AndroidManifest.xml")
    [ -d "$apk_dir/res"                 ] && files+=("res")

    cd "$apk_dir"
    if has_cmd zip; then
        zip -qr "$output" "${files[@]}"
    elif [ "$OS" = "windows" ] && has_cmd powershell; then
        local win_out="${output//\//\\}"
        powershell -NoProfile -Command "
            Add-Type -Assembly 'System.IO.Compression.FileSystem'
            \$z = [IO.Compression.ZipFile]::Open('${win_out}','Create')
            foreach (\$f in @($(printf "'%s'," "${files[@]}"))) {
                [IO.Compression.ZipFileExtensions]::CreateEntryFromFile(\$z,\$f,\$f) | Out-Null
            }
            \$z.Dispose()
        " || { error "PowerShell zip failed"; cd - >/dev/null; exit 1; }
    elif has_cmd python3; then
        python3 -c "
import zipfile, os, sys
files = sys.argv[1:]
with zipfile.ZipFile('${output}','w',zipfile.ZIP_DEFLATED) as z:
    for f in files:
        if os.path.isdir(f):
            for root,dirs,fs in os.walk(f):
                for ff in fs: z.write(os.path.join(root,ff))
        else:
            z.write(f)
" "${files[@]}"
    else
        error "Нужен zip, PowerShell или python3"; cd - >/dev/null; exit 1
    fi
    cd - >/dev/null
}

# ══════════════════════════════════════════════════════════════════
#  ГЕНЕРАЦИЯ AndroidManifest.xml
# ══════════════════════════════════════════════════════════════════
gen_manifest() {
    local dest="$1" pkg="$2" app_name="$3" main_activity="${4:-MainActivity}"
    cat > "$dest" << MANIFEST
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="${pkg}" android:versionCode="1" android:versionName="1.0">
    <uses-sdk android:minSdkVersion="21" android:targetSdkVersion="34"/>
    <application android:label="${app_name}" android:allowBackup="true">
        <activity android:name=".${main_activity}" android:exported="true"
            android:configChanges="orientation|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
MANIFEST
}

# ══════════════════════════════════════════════════════════════════
#  SIGN APK
# ══════════════════════════════════════════════════════════════════
sign_apk() {
    local java_bin="$1" unsigned="$2" output="$3" keystore="$4" alias="$5" storepass="$6" keypass="$7"

    set +e
    "$java_bin" -jar "$TOOLS_DIR/apksig.jar" sign \
        --ks "$keystore" --ks-pass "pass:$storepass" \
        --ks-key-alias "$alias" --key-pass "pass:$keypass" \
        --in "$unsigned" --out "$output" 2>&1 | \
        while IFS= read -r l; do
            echo -e "    ${DIM}${l}${RESET}"
            [ -n "$LOG_FILE" ] && log_line "$l"
        done
    local rc=${PIPESTATUS[0]}
    set -e
    return $rc
}

# ══════════════════════════════════════════════════════════════════
#  СБОРКА APK (debug / release)
# ══════════════════════════════════════════════════════════════════
install_apk() {
    local raw_files="$1"
    local mode="${2:-debug}"   # debug | release
    print_banner
    log_init "build_apk_${mode}"
    lstep "Сборка APK [${mode}] — автономный режим"
    divider

    [ -z "$raw_files" ] && { lerror "Файлы не указаны"; exit 1; }
    IFS='+' read -ra FILES <<< "$raw_files"

    lstep "Проверяю исходные файлы..."
    local all_ok=true
    for i in "${!FILES[@]}"; do
        FILES[$i]="$(echo "${FILES[$i]}" | xargs)"
        if [ -f "${FILES[$i]}" ]; then lsuccess "  ${FILES[$i]}"
        else lerror "  ${FILES[$i]} — не найден"; all_ok=false; fi
    done
    $all_ok || { lerror "Исправь пути к файлам"; exit 1; }

    lstep "Проверяю окружение..."
    local java_bin; java_bin="$(find_java)"
    [ -z "$java_bin" ] && { lerror "Java не установлена: tux install java"; exit 1; }
    lsuccess "  Java: $($java_bin -version 2>&1 | head -1)"

    local kotlinc_bin; kotlinc_bin="$(find_kotlinc)"
    [ -z "$kotlinc_bin" ] && { lerror "Kotlin не установлен: tux install kotlin"; exit 1; }
    lsuccess "  Kotlin: $($kotlinc_bin -version 2>&1 | head -1)"

    ensure_apk_tools

    local project_name
    project_name="$(basename "${FILES[0]}" .kt | sed 's/[^a-zA-Z0-9_]//g')"
    local pkg_name="com.tux.$(echo "$project_name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]//g')"
    local build_dir="$TMP_DIR/${project_name}_$$"
    local output_apk="$(pwd)/${project_name}-${mode}.apk"

    rm -rf "$build_dir"
    mkdir -p "$build_dir/src" "$build_dir/dex" "$build_dir/apk"
    for f in "${FILES[@]}"; do cp "$f" "$build_dir/src/"; done

    linfo "Проект: ${BOLD}${project_name}${RESET}"
    linfo "Режим:  ${BOLD}${mode}${RESET}"

    # ── Шаг 1: Kotlin → JAR ───────────────────────────────────
    lstep "Шаг 1/5 — Kotlin → JAR..."
    local kt_files=()
    for f in "${FILES[@]}"; do kt_files+=("$build_dir/src/$(basename "$f")"); done

    set +e
    "$kotlinc_bin" -classpath "$TOOLS_DIR/android.jar" \
        "${kt_files[@]}" -include-runtime -d "$build_dir/app.jar" 2>&1 | \
        while IFS= read -r l; do
            echo -e "    ${DIM}${l}${RESET}"
            [ -n "$LOG_FILE" ] && log_line "$l"
        done
    local kc_rc=${PIPESTATUS[0]}
    set -e
    [ $kc_rc -ne 0 ] && { lerror "Ошибка компиляции Kotlin"; rm -rf "$build_dir"; exit 1; }
    lsuccess "  → app.jar ($(du -sh "$build_dir/app.jar" | cut -f1))"

    # ── Шаг 2: JAR → DEX ──────────────────────────────────────
    lstep "Шаг 2/5 — JAR → Android DEX (R8/D8)..."
    local d8_args=(
        -cp "$TOOLS_DIR/r8.jar" com.android.tools.r8.D8
        --min-api 21
        --lib "$TOOLS_DIR/android.jar"
        --output "$build_dir/dex/"
    )
    [ "$mode" = "release" ] && d8_args+=(--release)

    set +e
    "$java_bin" "${d8_args[@]}" "$build_dir/app.jar" 2>&1 | \
        while IFS= read -r l; do
            echo -e "    ${DIM}${l}${RESET}"
            [ -n "$LOG_FILE" ] && log_line "$l"
        done
    local d8_rc=${PIPESTATUS[0]}
    set -e

    if [ $d8_rc -ne 0 ] || [ ! -f "$build_dir/dex/classes.dex" ]; then
        lwarn "  Пробую без --release..."
        "$java_bin" -cp "$TOOLS_DIR/r8.jar" com.android.tools.r8.D8 \
            --min-api 21 --lib "$TOOLS_DIR/android.jar" \
            --output "$build_dir/dex/" "$build_dir/app.jar" || \
            { lerror "DEX конвертация провалилась"; rm -rf "$build_dir"; exit 1; }
    fi
    lsuccess "  → classes.dex ($(du -sh "$build_dir/dex/classes.dex" | cut -f1))"

    # ── Шаг 3: Манифест ───────────────────────────────────────
    lstep "Шаг 3/5 — Генерирую AndroidManifest.xml..."
    local main_activity="MainActivity"
    for f in "${FILES[@]}"; do
        if grep -qE "class .+(Activity|Fragment)|fun main\b" "$f" 2>/dev/null; then
            local found; found=$(grep -oE 'class [A-Za-z]+' "$f" | head -1 | awk '{print $2}')
            [ -n "$found" ] && main_activity="$found" && break
        fi
    done
    cp "$build_dir/dex/classes.dex" "$build_dir/apk/"
    gen_manifest "$build_dir/apk/AndroidManifest.xml" "$pkg_name" "$project_name" "$main_activity"
    lsuccess "  → AndroidManifest.xml (pkg: ${pkg_name})"

    # ── Шаг 4: Упаковка ZIP ───────────────────────────────────
    lstep "Шаг 4/5 — Упаковываю APK..."
    local unsigned="$build_dir/${project_name}-unsigned.apk"
    pack_apk_zip "$build_dir/apk" "$unsigned"
    lsuccess "  → unsigned APK"

    # ── Шаг 5: Подпись ────────────────────────────────────────
    lstep "Шаг 5/5 — Подписываю APK (${mode})..."

    local keystore alias storepass keypass
    if [ "$mode" = "release" ]; then
        echo ""
        echo -e "  ${BOLD}Параметры release-подписи:${RESET}"
        echo -ne "  Путь к keystore [Enter = создать новый]: "
        read -r ks_path
        if [ -z "$ks_path" ]; then
            # Создаём release keystore
            local rel_ks="$(pwd)/${project_name}-release.keystore"
            echo -ne "  Псевдоним ключа (alias) [${project_name}]: "; read -r ks_alias
            echo -ne "  Пароль keystore: "; read -rs ks_pass; echo ""
            ks_alias="${ks_alias:-$project_name}"
            echo -ne "  Имя (CN) [My App]: "; read -r ks_cn; ks_cn="${ks_cn:-My App}"
            "$java_bin" -jar "$JAVA_DIR/lib/tools.jar" 2>/dev/null || true
            "$JAVA_DIR/bin/keytool${EXE_EXT}" \
                -genkeypair -keystore "$rel_ks" \
                -alias "$ks_alias" -keyalg RSA -keysize 2048 -validity 9999 \
                -storepass "$ks_pass" -keypass "$ks_pass" \
                -dname "CN=${ks_cn},O=MyOrg,C=US" 2>/dev/null && \
                lsuccess "  Release keystore создан: $rel_ks"
            keystore="$rel_ks"; alias="$ks_alias"; storepass="$ks_pass"; keypass="$ks_pass"
        else
            keystore="$ks_path"
            echo -ne "  Alias: "; read -r alias
            echo -ne "  Store password: "; read -rs storepass; echo ""
            keypass="$storepass"
        fi
    else
        # Debug подпись
        keystore="$TOOLS_DIR/tux-debug.keystore"
        alias="tuxdebug"; storepass="tuxdebug"; keypass="tuxdebug"
    fi

    if [ -f "$TOOLS_DIR/apksig.jar" ] && [ -f "$keystore" ]; then
        if sign_apk "$java_bin" "$unsigned" "$output_apk" "$keystore" "$alias" "$storepass" "$keypass"; then
            lsuccess "  APK подписан (v2 signature) ✓"
        else
            lwarn "  Подпись не удалась — копирую без подписи"
            cp "$unsigned" "$output_apk"
        fi
    else
        lwarn "  Подпись пропущена"
        cp "$unsigned" "$output_apk"
    fi

    rm -rf "$build_dir"
    log_line "OUTPUT: $output_apk"

    echo ""
    divider
    echo -e "\n  ${GREEN}${BOLD}✓ APK [${mode}] собран!${RESET}\n"
    echo -e "  ${BOLD}Файл:${RESET}   ${CYAN}${output_apk}${RESET}"
    echo -e "  ${BOLD}Размер:${RESET} $(du -sh "$output_apk" 2>/dev/null | cut -f1)"
    echo -e "  ${BOLD}Пакет:${RESET}  ${DIM}${pkg_name}${RESET}"
    echo -e "  ${BOLD}Лог:${RESET}    ${DIM}${LOG_FILE}${RESET}"
    echo ""
    echo -e "  ${BOLD}Установка:${RESET}  ${CYAN}adb install $(basename "$output_apk")${RESET}"
    echo ""
}

# ══════════════════════════════════════════════════════════════════
#  СБОРКА AAB (Android App Bundle)
#  AAB = ZIP с особой структурой для Google Play
# ══════════════════════════════════════════════════════════════════
build_aab() {
    local raw_files="$1"
    print_banner
    log_init "build_aab"
    lstep "Сборка AAB (Android App Bundle для Google Play)"
    divider

    [ -z "$raw_files" ] && { lerror "Файлы не указаны"; exit 1; }
    IFS='+' read -ra FILES <<< "$raw_files"

    lstep "Проверяю файлы..."
    local all_ok=true
    for i in "${!FILES[@]}"; do
        FILES[$i]="$(echo "${FILES[$i]}" | xargs)"
        [ -f "${FILES[$i]}" ] && lsuccess "  ${FILES[$i]}" || { lerror "  ${FILES[$i]} — не найден"; all_ok=false; }
    done
    $all_ok || exit 1

    local java_bin; java_bin="$(find_java)"
    [ -z "$java_bin" ] && { lerror "Java не установлена: tux install java"; exit 1; }
    local kotlinc_bin; kotlinc_bin="$(find_kotlinc)"
    [ -z "$kotlinc_bin" ] && { lerror "Kotlin не установлен: tux install kotlin"; exit 1; }

    ensure_apk_tools

    local project_name
    project_name="$(basename "${FILES[0]}" .kt | sed 's/[^a-zA-Z0-9_]//g')"
    local pkg_name="com.tux.$(echo "$project_name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]//g')"
    local build_dir="$TMP_DIR/${project_name}_aab_$$"
    local output_aab="$(pwd)/${project_name}.aab"

    rm -rf "$build_dir"
    # Структура AAB: base/dex/  base/manifest/  base/res/  base/root/
    mkdir -p \
        "$build_dir/src" \
        "$build_dir/aab/base/dex" \
        "$build_dir/aab/base/manifest" \
        "$build_dir/aab/base/res/layout" \
        "$build_dir/aab/base/root"

    for f in "${FILES[@]}"; do cp "$f" "$build_dir/src/"; done

    # ── Шаг 1: Kotlin → JAR ──────────────────────────────────
    lstep "Шаг 1/4 — Kotlin → JAR..."
    local kt_files=()
    for f in "${FILES[@]}"; do kt_files+=("$build_dir/src/$(basename "$f")"); done
    set +e
    "$kotlinc_bin" -classpath "$TOOLS_DIR/android.jar" \
        "${kt_files[@]}" -include-runtime -d "$build_dir/app.jar" 2>&1 | \
        while IFS= read -r l; do echo -e "    ${DIM}${l}${RESET}"; [ -n "$LOG_FILE" ] && log_line "$l"; done
    local kc_rc=${PIPESTATUS[0]}
    set -e
    [ $kc_rc -ne 0 ] && { lerror "Ошибка компиляции"; rm -rf "$build_dir"; exit 1; }
    lsuccess "  → app.jar"

    # ── Шаг 2: JAR → DEX ─────────────────────────────────────
    lstep "Шаг 2/4 — JAR → DEX (R8)..."
    "$java_bin" -cp "$TOOLS_DIR/r8.jar" com.android.tools.r8.D8 \
        --release --min-api 21 \
        --lib "$TOOLS_DIR/android.jar" \
        --output "$build_dir/aab/base/dex/" \
        "$build_dir/app.jar" 2>/dev/null || \
    "$java_bin" -cp "$TOOLS_DIR/r8.jar" com.android.tools.r8.D8 \
        --min-api 21 --lib "$TOOLS_DIR/android.jar" \
        --output "$build_dir/aab/base/dex/" "$build_dir/app.jar" || \
        { lerror "DEX ошибка"; rm -rf "$build_dir"; exit 1; }
    lsuccess "  → classes.dex"

    # ── Шаг 3: Манифест + метаданные AAB ─────────────────────
    lstep "Шаг 3/4 — Создаю структуру AAB..."
    local main_activity="MainActivity"
    for f in "${FILES[@]}"; do
        if grep -qE "class .+(Activity)" "$f" 2>/dev/null; then
            local found; found=$(grep -oE 'class [A-Za-z]+' "$f" | head -1 | awk '{print $2}')
            [ -n "$found" ] && main_activity="$found" && break
        fi
    done

    gen_manifest "$build_dir/aab/base/manifest/AndroidManifest.xml" \
        "$pkg_name" "$project_name" "$main_activity"

    # BundleConfig.pb заглушка (protobuf, минимальная)
    # Создаём текстовую версию (bundletool может читать)
    cat > "$build_dir/aab/BundleConfig.json" << BCFG
{
    "bundletool": {"version": "1.15.0"},
    "optimizations": {
        "splitsConfig": {
            "splitDimension": [
                {"value": "ABI",      "negate": false, "suffixStripping": {"enabled": true}},
                {"value": "SCREEN_DENSITY", "negate": false, "suffixStripping": {"enabled": true}},
                {"value": "LANGUAGE", "negate": true}
            ]
        }
    }
}
BCFG

    # Минимальный resources.pb (бинарный proto — пустой)
    printf '\x0a\x00' > "$build_dir/aab/base/resources.pb"

    lsuccess "  → base/manifest/AndroidManifest.xml"
    lsuccess "  → BundleConfig.json"

    # ── Шаг 4: Упаковка AAB (ZIP) ────────────────────────────
    lstep "Шаг 4/4 — Упаковываю AAB..."
    cd "$build_dir/aab"
    local unsigned_aab="$build_dir/${project_name}-unsigned.aab"

    if has_cmd zip; then
        zip -qr "$unsigned_aab" base/ BundleConfig.json
    elif has_cmd python3; then
        python3 -c "
import zipfile, os
with zipfile.ZipFile('${unsigned_aab}','w',zipfile.ZIP_DEFLATED) as z:
    for root,dirs,files in os.walk('base'):
        for f in files: z.write(os.path.join(root,f))
    z.write('BundleConfig.json')
"
    else
        error "Нужен zip или python3"; cd - >/dev/null; exit 1
    fi
    cd - >/dev/null

    # Подпись AAB
    if [ -f "$TOOLS_DIR/apksig.jar" ] && [ -f "$TOOLS_DIR/tux-debug.keystore" ]; then
        sign_apk "$java_bin" "$unsigned_aab" "$output_aab" \
            "$TOOLS_DIR/tux-debug.keystore" "tuxdebug" "tuxdebug" "tuxdebug" && \
            lsuccess "  AAB подписан" || { lwarn "  Подпись AAB не удалась"; cp "$unsigned_aab" "$output_aab"; }
    else
        cp "$unsigned_aab" "$output_aab"
    fi

    rm -rf "$build_dir"
    log_line "OUTPUT: $output_aab"

    echo ""
    divider
    echo -e "\n  ${GREEN}${BOLD}✓ AAB собран!${RESET}\n"
    echo -e "  ${BOLD}Файл:${RESET}   ${CYAN}${output_aab}${RESET}"
    echo -e "  ${BOLD}Размер:${RESET} $(du -sh "$output_aab" 2>/dev/null | cut -f1)"
    echo -e "  ${BOLD}Пакет:${RESET}  ${DIM}${pkg_name}${RESET}"
    echo -e "  ${BOLD}Лог:${RESET}    ${DIM}${LOG_FILE}${RESET}"
    echo ""
    echo -e "  ${BOLD}Загрузка в Google Play:${RESET}"
    echo -e "  ${DIM}  play.google.com/console → Выпуск → Загрузить AAB${RESET}"
    echo ""
    echo -e "  ${BOLD}Тест локально (bundletool):${RESET}"
    echo -e "  ${CYAN}  bundletool build-apks --bundle=$(basename "$output_aab") --output=app.apks${RESET}"
    echo -e "  ${CYAN}  bundletool install-apks --apks=app.apks${RESET}"
    echo ""
}

