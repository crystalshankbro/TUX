# ══════════════════════════════════════════════════════════════════
#  SELF-INSTALL — добавляет tux в PATH навсегда
# ══════════════════════════════════════════════════════════════════
self_install() {
    print_banner
    step "Установка Tux в систему"
    divider

    local SCRIPT_PATH
    # Получаем абсолютный путь к самому себе
    SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

    # Определяем куда установить
    local install_dir needs_sudo=false
    if [ -d "/usr/local/bin" ] && [ -w "/usr/local/bin" ]; then
        install_dir="/usr/local/bin"
    elif [ -d "/usr/local/bin" ]; then
        install_dir="/usr/local/bin"
        needs_sudo=true
    else
        install_dir="$HOME/.local/bin"
        mkdir -p "$install_dir"
    fi

    info "Устанавливаю в: ${BOLD}${install_dir}/tux${RESET}"

    # Копируем себя в install_dir (если уже не там)
    if [ "$SCRIPT_PATH" != "$install_dir/tux" ]; then
        if [ "$needs_sudo" = true ]; then
            sudo cp "$SCRIPT_PATH" "$install_dir/tux"
            sudo chmod +x "$install_dir/tux"
        else
            cp "$SCRIPT_PATH" "$install_dir/tux"
            chmod +x "$install_dir/tux"
        fi
        success "tux скопирован в $install_dir/tux"
    else
        info "tux уже находится в $install_dir"
    fi

    # Добавляем в PATH если нужно
    local needs_path=false
    echo "$PATH" | grep -q "$install_dir" || needs_path=true

    if [ "$needs_path" = true ]; then
        info "Добавляю $install_dir в PATH..."
        local export_line="export PATH=\"${install_dir}:\$PATH\""
        local added=false
        for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.bash_profile" "$HOME/.profile"; do
            if [ -f "$rc" ] && ! grep -qF "$install_dir" "$rc"; then
                { echo ""; echo "# Added by Tux"; echo "$export_line"; } >> "$rc"
                success "  Добавлено в $(basename "$rc")"
                added=true
            fi
        done
        # Если нет ни одного rc — создаём .bashrc
        if [ "$added" = false ] && [ ! -f "$HOME/.bashrc" ]; then
            echo "$export_line" > "$HOME/.bashrc"
            success "  Создан ~/.bashrc"
        fi
        export PATH="$install_dir:$PATH"
    fi

    echo ""
    divider
    echo -e "\n  ${GREEN}${BOLD}✓ Tux установлен!${RESET}\n"

    if [ "$needs_path" = true ] && [ "$install_dir" = "$HOME/.local/bin" ]; then
        echo -e "  ${YELLOW}Перезапусти терминал или выполни:${RESET}"
        echo -e "    ${CYAN}source ~/.bashrc${RESET}"
        echo ""
        echo -e "  После этого просто пиши ${BOLD}tux${RESET} в любом терминале"
    else
        echo -e "  Теперь просто пиши ${BOLD}tux${RESET} в любом терминале — как python или git"
    fi
    echo ""
}

# ══════════════════════════════════════════════════════════════════
#  ВЕРСИИ
# ══════════════════════════════════════════════════════════════════
show_version() { show_list; }

# ══════════════════════════════════════════════════════════════════
#  ТОЧКА ВХОДА
# ══════════════════════════════════════════════════════════════════
main() {
    case "${1:-}" in
        install)
            case "${2:-}" in
                java)    install_java ;;
                kotlin)  install_kotlin ;;
                gradle)  install_gradle ;;
                python)  install_python ;;
                node)    install_node ;;
                apk)
                    [ -z "${3:-}" ] && { error "tux install apk Main.kt+B.kt [release]"; exit 1; }
                    install_apk "$3" "${4:-debug}"
                    ;;
                "")  error "Укажи пакет: java kotlin gradle python node apk"; exit 1 ;;
                *)   error "Неизвестный пакет: '${2}'"; exit 1 ;;
            esac ;;
        build)
            case "${2:-}" in
                aab)
                    [ -z "${3:-}" ] && { error "tux build aab Main.kt+B.kt"; exit 1; }
                    build_aab "$3"
                    ;;
                *)  error "tux build aab <файлы>"; exit 1 ;;
            esac ;;
        list)              show_list ;;
        logs)              show_logs ;;
        update-tools)      update_tools ;;
        self-install)      self_install ;;
        version|--version) show_version ;;
        help|--help|-h)    show_help ;;
        "")                interactive_menu ;;  # Главное меню без аргументов!
        *)
            error "Неизвестная команда: '${1}'"
            echo -e "  ${DIM}tux help${RESET}"
            exit 1 ;;
    esac
}

main "$@"
